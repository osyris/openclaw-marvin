# === Platform env files (Coolify/Railway inject these at runtime) ===
.env
.env_

# === OpenClaw secrets & state ===
.openclaw/openclaw.json
!.openclaw/openclaw.sanitized.json
.openclaw/openclaw.json.bak*
.openclaw/.env
.openclaw/credentials/
.openclaw/agents/*/agent/auth-profiles.json
.openclaw/identity/
.openclaw/devices/
.openclaw/browser/
.openclaw/media/
.openclaw/delivery-queue/
.openclaw/subagents/
.openclaw/telegram/

# Sessions (transcripts, locks, state)
.openclaw/agents/*/sessions/

# Other openclaw temp/state
.openclaw/filebrowser.db
.openclaw/update-check.json
.openclaw/canvas/

# === Workspace secrets & temp ===
workspace/memory/booking-session.json

# Node modules
workspace/node_modules/
workspace/package-lock.json

# Workspace transcript files (leaked from old config)
workspace/*.jsonl

# SSH private key (public + setup ok)
.ssh/marvin_deploy
.ssh/known_hosts*

# Project repos (cloned separately, not part of workspace)
projects/

# OS junk
.DS_Store
Thumbs.db
openclaw.tar.gz
.openclaw_bak/
